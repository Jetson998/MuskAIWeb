WEBUI_DOCKER_TAG=main
WEBUI_PORT=3000
WEBUI_AUTH=true
WEBUI_SECRET_KEY=change-me-before-production

# Optional local Ollama endpoint.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI-compatible provider defaults.
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Image generation uses Open WebUI's Images backend. Do not select this model
# as the chat model; keep a normal text model selected in conversations.
ENABLE_IMAGE_GENERATION=true
IMAGE_GENERATION_ENGINE=openai
IMAGE_GENERATION_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024
ENABLE_IMAGE_PROMPT_GENERATION=false
ENABLE_IMAGE_EDIT=true
IMAGE_EDIT_ENGINE=openai
IMAGE_EDIT_MODEL=gpt-image-2
IMAGE_EDIT_SIZE=1024x1024

# Optional overrides. Leave commented to reuse OPENAI_API_BASE_URL and OPENAI_API_KEY.
# IMAGES_OPENAI_API_BASE_URL=https://api.openai.com/v1
# IMAGES_OPENAI_API_KEY=
# IMAGES_EDIT_OPENAI_API_BASE_URL=https://api.openai.com/v1
# IMAGES_EDIT_OPENAI_API_KEY=
